<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>id_firmadoc</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>id_firmante</name>
        <type>integer</type>
        <null>YES</null>
    </column>
    <column>
        <name>email_destino</name>
        <type>character varying(150)</type>
        <null>NO</null>
    </column>
    <column>
        <name>nombre_destino</name>
        <type>character varying(150)</type>
        <null>YES</null>
    </column>
    <column>
        <name>tipo</name>
        <type>character varying(20)</type>
        <null>NO</null>
        <default>'inicial'</default>
    </column>
    <column>
        <name>fecha</name>
        <type>timestamp without time zone</type>
        <null>NO</null>
        <default>CURRENT_TIMESTAMP</default>
    </column>
    <column>
        <name>canal</name>
        <type>character varying(10)</type>
        <null>NO</null>
        <default>'email'</default>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
        <null>YES</null>
    </column>
    <constraint>
        <name>firmadoc_reenvio_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>firmadoc_reenvio_firmadoc_fkey</name>
        <type>FOREIGN KEY (id_firmadoc) REFERENCES firmadoc (id) ON DELETE CASCADE</type>
    </constraint>
</table>
