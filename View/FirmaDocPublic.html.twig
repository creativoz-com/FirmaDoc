// === PAD DE FIRMA MANUSCRITA ===
const canvas = document.getElementById('canvas-firma');
let ctx, dibujando = false, modoActual = '{% if fsc.config.modo_manuscrita %}manuscrita{% elseif fsc.config.modo_tipografica %}tipografica{% else %}certificado{% endif %}';
let firmaBackup = null; // ImageData backup para preservar firma en resize

if (canvas) {
    ctx = canvas.getContext('2d');
    ctx.strokeStyle = '#1a1a2e';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ajustarCanvas();

    canvas.addEventListener('mousedown', iniciarDibujo);
    canvas.addEventListener('mousemove', dibujar);
    canvas.addEventListener('mouseup', () => dibujando = false);
    canvas.addEventListener('mouseleave', () => dibujando = false);
    canvas.addEventListener('touchstart', e => { e.preventDefault(); iniciarDibujo(e.touches[0]); }, {passive: false});
    canvas.addEventListener('touchmove', e => { e.preventDefault(); dibujar(e.touches[0]); }, {passive: false});
    canvas.addEventListener('touchend', () => dibujando = false);
}

function ajustarCanvas() {
    const w = canvas.parentElement.clientWidth - 40;
    // Guardar firma antes de redimensionar (canvas.width = X borra el contenido)
    var backupImg = null;
    var oldW = canvas.width;
    var oldH = canvas.height;
    if (oldW > 0 && oldH > 0) {
        try { backupImg = ctx.getImageData(0, 0, oldW, oldH); } catch(e) {}
    }
    canvas.width = w;
    ctx.strokeStyle = '#1a1a2e';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    // Restaurar firma si existía
    if (backupImg && oldW === w) {
        ctx.putImageData(backupImg, 0, 0);
    } else if (backupImg) {
        // Si cambió el ancho, redibujar escalado via imagen temporal
        var tempCanvas = document.createElement('canvas');
        tempCanvas.width = oldW;
        tempCanvas.height = oldH;
        tempCanvas.getContext('2d').putImageData(backupImg, 0, 0);
        ctx.drawImage(tempCanvas, 0, 0, w, canvas.height);
    }
}

function getPosicion(e) {
    const rect = canvas.getBoundingClientRect();
    return {
        x: (e.clientX - rect.left) * (canvas.width / rect.width),
        y: (e.clientY - rect.top) * (canvas.height / rect.height)
    };
}

function iniciarDibujo(e) {
    dibujando = true;
    canvas.classList.add('activo');
    const pos = getPosicion(e);
    ctx.beginPath();
    ctx.moveTo(pos.x, pos.y);
}

function dibujar(e) {
    if (!dibujando) return;
    const pos = getPosicion(e);
    ctx.lineTo(pos.x, pos.y);
    ctx.stroke();
}

function limpiarCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    canvas.classList.remove('activo');
}

