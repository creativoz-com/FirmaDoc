<!DOCTYPE html>
<html lang="{{ constant('FS_LANG') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ fsc.firma.codigo_doc ?? trans('firmadoc-title') }} — {{ trans('firmadoc-electronic-signature') }}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body { background: #f5f6fa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .firma-card { max-width: 680px; margin: 30px auto; background: #fff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); overflow: hidden; }
        .firma-header { background: linear-gradient(135deg, #1a7a4a 0%, #2ecc71 100%); color: #fff; padding: 28px 32px 20px; }
        .firma-header h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 4px; }
        .firma-header p { margin: 0; opacity: 0.85; font-size: 0.95rem; }
        .firma-body { padding: 28px 32px; }
        #canvas-firma { border: 2px dashed #dee2e6; border-radius: 8px; cursor: crosshair; background: #fafafa; touch-action: none; width: 100%; }
        #canvas-firma.activo { border-color: #1a7a4a; background: #fff; }
        .tabs-modo { display: flex; background: #f0f0f0; border-radius: 10px; padding: 3px; margin-bottom: 16px; gap: 3px; }
        .tab-modo { cursor: pointer; flex: 1; text-align: center; padding: 10px 6px 8px; border-radius: 8px; border: none; background: transparent; font-size: 0.75rem; color: #666; transition: all 0.2s ease; line-height: 1.2; }
        .tab-modo i { display: block; font-size: 1.3rem; margin-bottom: 4px; }
        .tab-modo span { display: block; }
        .tab-modo.activo { background: #fff; font-weight: 600; color: #1a7a4a; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
        .panel-modo { border: 1px solid #dee2e6; border-radius: 10px; padding: 20px; background: #fff; }
        .firma-tipografica-preview { font-family: 'Dancing Script', cursive; font-size: 2.5rem; color: #1a4a8a; min-height: 80px; border-bottom: 2px solid #dee2e6; text-align: center; padding: 10px; letter-spacing: 2px; }
        .btn-firmar { background: linear-gradient(135deg, #1a7a4a, #2ecc71); border: none; color: #fff; padding: 14px 40px; font-size: 1.1rem; font-weight: 600; border-radius: 8px; width: 100%; margin-top: 10px; }
        .btn-firmar:hover { opacity: 0.9; color: #fff; }
        .doc-info { background: #f8f9fa; border-radius: 8px; padding: 14px 18px; margin-bottom: 20px; font-size: 0.9rem; }
        .doc-info strong { color: #333; }
        .alerta { border-radius: 8px; padding: 16px 20px; margin-bottom: 20px; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&display=swap" rel="stylesheet">
    {% if fsc.config.modo_certificado %}
    <script src="{{ fsc.urlBase }}/Plugins/FirmaDoc/Assets/autoscript.js?v=2.63"></script>
    {% endif %}
</head>
<body>

<div class="firma-card">

    {# CABECERA #}
    <div class="firma-header">
        <h1><i class="fas fa-signature mr-2"></i> {{ trans('firmadoc-electronic-signature') }}</h1>
        <p>{{ trans('firmadoc-review-and-sign') }}</p>
    </div>

    <div class="firma-body">

        {# MENSAJE DE ESTADO #}
        {% if fsc.mensaje %}
        <div class="alerta alert-{% if fsc.mensajeTipo == 'success' %}success{% elseif fsc.mensajeTipo == 'danger' %}danger{% elseif fsc.mensajeTipo == 'warning' %}warning{% else %}info{% endif %}">
            {% if fsc.mensajeTipo == 'success' %}
                <i class="fas fa-check-circle mr-2"></i>
            {% elseif fsc.mensajeTipo == 'danger' %}
                <i class="fas fa-times-circle mr-2"></i>
            {% else %}
                <i class="fas fa-info-circle mr-2"></i>
            {% endif %}
            {{ fsc.mensaje }}
        </div>
        {% endif %}

        {# PROGRESO MULTI-FIRMANTE — visible siempre que haya más de 1 firmante #}
        {% if fsc.firmantesTotal > 1 %}
        <div style="background:#f8f9fa;border-radius:8px;padding:12px 16px;margin-bottom:16px;border:1px solid #dee2e6">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <small class="font-weight-bold text-secondary">
              <i class="fas fa-users mr-1"></i>{{ trans('firmadoc-signing-progress') }}
            </small>
            <small class="text-secondary">
              {{ trans('firmadoc-x-of-y-signers', {'%signed%': fsc.firmantesHanFirmado, '%total%': fsc.firmantesTotal}) }}
            </small>
          </div>
          <div style="background:#dee2e6;border-radius:4px;height:8px;overflow:hidden">
            {% set pct = fsc.firmantesTotal > 0 ? (fsc.firmantesHanFirmado / fsc.firmantesTotal * 100)|round : 0 %}
            <div style="background:#28a745;height:100%;width:{{ pct }}%;transition:width .4s;min-width:{{ pct > 0 ? '4px' : '0' }}"></div>
          </div>
        </div>
        {% endif %}

        {# INFO DEL DOCUMENTO + VISOR PDF INLINE #}
        {% if fsc.firma %}
        <div class="doc-info">
            <div class="row align-items-center">
                <div class="col-6">
                    <strong>{{ trans('firmadoc-document') }}:</strong><br>
                    {{ fsc.firma.tipo_doc|capitalize }} {{ fsc.firma.codigo_doc }}
                </div>
                <div class="col-6">
                    {% if fsc.firma.estado == 'firmado' %}
                    <strong>{{ trans('firmadoc-signed-on') }}:</strong><br>
                    {{ fsc.firma.fecha_firma }}
                    {% elseif fsc.firma.estado == 'cancelado' %}
                    <strong>{{ trans('firmadoc-status') }}:</strong><br>
                    <span style="color:#c0392b;font-weight:600;">{{ trans('firmadoc-status-rejected') }}</span>
                    {% else %}
                    <strong>{{ trans('firmadoc-valid-until') }}:</strong><br>
                    {{ fsc.firma.fecha_expiracion }}
                    {% endif %}
                </div>
            </div>

            {# Visor PDF — se muestra siempre (sin firmas si el proceso está en curso) #}
            {% set esMultiFirmanteParcial = fsc.firmantesTotal > 1 and fsc.firma.estado != 'firmado' %}
            {% if fsc.linkDocumento
               and fsc.firma.estado not in ['cancelado', 'expirado', 'anulado_mod']
               and (fsc.config.descarga_pdf == 'siempre'
                    or fsc.firma.estado == 'firmado'
                    or fsc.config.descarga_pdf == 'posfirma') %}

            {# Aviso legal cuando hay firmantes pendientes #}
            {% if esMultiFirmanteParcial %}
            <div style="background:#fff8e1;border:1px solid #ffe082;border-radius:6px;padding:10px 14px;margin-bottom:10px;font-size:0.85em;color:#5d4037">
              <i class="fas fa-info-circle mr-1" style="color:#f9a825"></i>
              {{ trans('firmadoc-note-original-document') | raw }}
            </div>
            {% endif %}
            <div class="mt-3">
                <div id="pdf-toggle" onclick="togglePdf()"
                     style="background:#f0f4ff;border:1px solid #c8d8f8;border-radius:8px;
                            padding:10px 14px;cursor:pointer;display:flex;
                            justify-content:space-between;align-items:center;user-select:none;">
                    <span style="font-weight:600;color:#2c5aa0;">
                        <i class="fas fa-file-pdf mr-2" style="color:#e53935;"></i>
                        {% if fsc.firma.estado == 'firmado' %}
                            {{ trans('firmadoc-view-signed-document') }}
                        {% elseif fsc.firmantesHanFirmado > 0 and fsc.firmantesTotal > 1 %}
                            {{ trans('firmadoc-view-document-progress', {'%signed%': fsc.firmantesHanFirmado, '%total%': fsc.firmantesTotal}) }}
                        {% else %}
                            {{ trans('firmadoc-view-document-before-signing') }}
                        {% endif %}
                    </span>
                    <span id="pdf-toggle-icon" style="color:#2c5aa0;font-size:1.1em;">
                        <i class="fas fa-chevron-down"></i>
                    </span>
                </div>
                <div id="pdf-viewer" style="display:none;margin-top:6px;border-radius:8px;overflow:hidden;border:1px solid #c8d8f8;">
                    <iframe src="{{ fsc.linkDocumento }}#toolbar=1&navpanes=0&scrollbar=1"
                            style="width:100%;height:420px;border:none;display:block;"
                            title="{{ trans('firmadoc-view-document-before-signing') }}">
                        <p>{{ trans('firmadoc-browser-no-preview') }}
                           <a href="{{ fsc.linkDocumento }}" target="_blank">{{ trans('firmadoc-download-pdf-here') }}</a>.
                        </p>
                    </iframe>
                    <div style="background:#f8f9ff;padding:8px 12px;text-align:right;border-top:1px solid #e0e8ff;">
                        <a href="{{ fsc.linkDocumento }}" target="_blank"
                           style="font-size:0.82em;color:#2c5aa0;text-decoration:none;">
                            <i class="fas fa-external-link-alt mr-1"></i> {{ trans('firmadoc-open-new-tab') }}
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
        {% endif %}


        {# FORMULARIO DE FIRMA #}
        {% if fsc.tokenValido %}
        <form method="post" id="formFirma">
            <input type="hidden" name="action" value="firmar">
            <input type="hidden" name="firma_imagen" id="firma_imagen">
            <input type="hidden" name="firma_certificado_data" id="firma_certificado_data">

            {# TABS DE MODO #}
            {% set modos = [] %}
            {% if fsc.config.modo_manuscrita %} {% set modos = modos|merge(['manuscrita']) %} {% endif %}
            {% if fsc.config.modo_tipografica %} {% set modos = modos|merge(['tipografica']) %} {% endif %}
            {% if fsc.config.modo_certificado %} {% set modos = modos|merge(['certificado']) %} {% endif %}

            {% if modos|length > 1 %}
            <div class="tabs-modo">
                {% if fsc.config.modo_manuscrita %}
                <div class="tab-modo activo" onclick="cambiarModo('manuscrita', this)">
                    <i class="fas fa-pen"></i>
                    <span>{{ trans('firmadoc-tab-handwritten-line1') }}</span>
                    <span>{{ trans('firmadoc-tab-handwritten-line2') }}</span>
                </div>
                {% endif %}
                {% if fsc.config.modo_tipografica %}
                <div class="tab-modo" onclick="cambiarModo('tipografica', this)">
                    <i class="fas fa-font"></i>
                    <span>{{ trans('firmadoc-tab-typographic-line1') }}</span>
                    <span>{{ trans('firmadoc-tab-typographic-line2') }}</span>
                </div>
                {% endif %}
                {% if fsc.config.modo_certificado %}
                <div class="tab-modo" onclick="cambiarModo('certificado', this)">
                    <i class="fas fa-id-card"></i>
                    <span>{{ trans('firmadoc-tab-certificate-line1') }}</span>
                    <span>{{ trans('firmadoc-tab-certificate-line2') }}</span>
                </div>
                {% endif %}
            </div>
            {% endif %}

            {# PANEL MANUSCRITA #}
            {% if fsc.config.modo_manuscrita %}
            <div class="panel-modo" id="panel-manuscrita">
                <p class="text-muted small mb-2">{{ trans('firmadoc-draw-signature') }}</p>
                <canvas id="canvas-firma" height="160"></canvas>
                <div class="mt-2 text-right">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="limpiarCanvas()">
                        <i class="fas fa-eraser mr-1"></i> {{ trans('firmadoc-clear') }}
                    </button>
                </div>
            </div>
            {% endif %}

            {# PANEL TIPOGRÁFICA #}
            {% if fsc.config.modo_tipografica %}
            <div class="panel-modo {% if fsc.config.modo_manuscrita %}d-none{% endif %}" id="panel-tipografica">
                <p class="text-muted small mb-2">{{ trans('firmadoc-type-full-name') }}</p>
                <input type="text" class="form-control mb-3" id="nombre-tipografico"
                    placeholder="{{ trans('firmadoc-your-full-name') }}"
                    oninput="actualizarFirmaTipografica(this.value)">
                <div class="firma-tipografica-preview" id="preview-tipografica"></div>
            </div>
            {% endif %}

            {# PANEL CERTIFICADO DIGITAL #}
            {% if fsc.config.modo_certificado %}
            <div class="panel-modo {% if fsc.config.modo_manuscrita or fsc.config.modo_tipografica %}d-none{% endif %}"
                 id="panel-certificado">
                {# Info para móvil: necesita app AutoFirma #}
                <div id="cert-mobile-info" style="display:none;padding:14px;border-radius:8px;
                     background:#e8f4fd;border:1px solid #bee5eb;margin-bottom:12px;">
                    <p class="small mb-2" style="color:#0c5460;">
                        <i class="fas fa-mobile-alt mr-1"></i>
                        <strong>{{ trans('firmadoc-cert-mobile-title') }}</strong><br>
                        {{ trans('firmadoc-cert-mobile-desc') }}
                    </p>
                    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;">
                        <a href="https://play.google.com/store/apps/details?id=es.gob.afirma" target="_blank"
                           class="btn btn-sm" style="background:#34a853;color:#fff;">
                            <i class="fab fa-google-play mr-1"></i> {{ trans('firmadoc-cert-mobile-android') }}
                        </a>
                        <a href="https://apps.apple.com/es/app/autofirma-app/id627410001" target="_blank"
                           class="btn btn-sm" style="background:#007aff;color:#fff;">
                            <i class="fab fa-apple mr-1"></i> {{ trans('firmadoc-cert-mobile-ios') }}
                        </a>
                    </div>
                </div>
                <p class="text-muted small mb-2">
                    {{ trans('firmadoc-sign-with-certificate') }}
                </p>
                <div id="cert-estado" style="padding:14px;border-radius:8px;background:#f8f9fa;
                     border:1px solid #dee2e6;text-align:center;">
                    <i class="fas fa-id-card fa-2x text-muted mb-2 d-block"></i>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">
                        <i class="fas fa-search mr-1"></i> {{ trans('firmadoc-select-certificate') }}
                    </button>
                    <p class="text-muted small mt-2 mb-0" id="cert-desktop-help">
                        {{ trans('firmadoc-need-autofirma') | raw }}
                        <a href="https://firmaelectronica.gob.es/Home/Descargas.html" target="_blank">{{ trans('firmadoc-download') }}</a>
                    </p>
                </div>
                <div id="cert-info" style="display:none;padding:14px;border-radius:8px;
                     background:#e8f5e9;border:1px solid #a5d6a7;">
                    <i class="fas fa-check-circle text-success mr-2"></i>
                    <strong id="cert-nombre-display"></strong><br>
                    <small class="text-muted">
                        {{ trans('firmadoc-nif-dni') }}: <span id="cert-nif-display"></span> &nbsp;·&nbsp;
                        {{ trans('firmadoc-valid-until-cert') }}: <span id="cert-expiry-display"></span>
                    </small>
                    <br><br>
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="iniciarAutofirma()">
                        <i class="fas fa-sync mr-1"></i> {{ trans('firmadoc-change-certificate') }}
                    </button>
                </div>
            </div>
            {% endif %}

            {# CAMPOS ADICIONALES #}
            <div class="mt-3">
                <div class="form-group">
                    <label class="font-weight-bold small">{{ trans('firmadoc-full-name') }} <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="firma_nombre" id="firma_nombre_input"
                        placeholder="{{ trans('firmadoc-name-and-surnames') }}" required>
                </div>

                {% if fsc.config.nif_modo != 'no' %}
                <div class="form-group">
                    <label class="font-weight-bold small">
                        {{ trans('firmadoc-nif-dni') }}
                        {% if fsc.config.nif_modo == 'obligatorio' %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    <input type="text" class="form-control" name="firma_nif" id="firma_nif_input"
                        placeholder="12345678A"
                        {% if fsc.config.nif_modo == 'obligatorio' %}required{% endif %}>
                </div>
                {% endif %}

                {% if fsc.config.cargo_modo != 'no' %}
                <div class="form-group">
                    <label class="font-weight-bold small">
                        {{ trans('firmadoc-position') }}
                        {% if fsc.config.cargo_modo == 'obligatorio' %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    <input type="text" class="form-control" name="firma_cargo"
                        placeholder="{{ trans('firmadoc-position-placeholder') }}"
                        {% if fsc.config.cargo_modo == 'obligatorio' %}required{% endif %}>
                </div>
                {% endif %}

                {% if fsc.config.legal_url or fsc.config.legal_texto %}
                <div class="form-group">
                    <div class="custom-control custom-checkbox">
                        <input type="checkbox" class="custom-control-input" id="acepto_legal"
                            name="acepto_legal" value="1" required>
                        <label class="custom-control-label small" for="acepto_legal">
                            {{ trans('firmadoc-accept-legal') }}
                            {% if fsc.config.legal_url %}
                                <a href="{{ fsc.config.legal_url }}" target="_blank">{{ trans('firmadoc-legal-notice') }}</a>
                            {% else %}
                                {{ trans('firmadoc-legal-notice') }}
                            {% endif %}
                            {{ trans('firmadoc-legal-consent') }}
                        </label>
                    </div>
                </div>
                {% endif %}

                {# OBSERVACIONES DEL FIRMANTE #}
                <div class="form-group mt-2">
                    <label class="small text-muted" for="observaciones_firmante">
                        <i class="fas fa-comment-alt mr-1"></i>
                        {{ trans('firmadoc-observations') }} <span class="text-muted">{{ trans('firmadoc-optional') }}</span>
                    </label>
                    <textarea id="observaciones_firmante" name="observaciones_firmante" rows="2"
                              placeholder="{{ trans('firmadoc-observations-placeholder') }}"
                              style="width:100%;border:1px solid #ddd;border-radius:8px;
                                     padding:10px;font-size:0.88em;resize:vertical;
                                     font-family:inherit;"></textarea>
                </div>
            </div>

            <button type="submit" class="btn btn-firmar" onclick="return prepararFirma()">
                <i class="fas fa-check-circle mr-2"></i> {{ trans('firmadoc-sign-document') }}
            </button>
        </form>

        {# BOTÓN RECHAZAR #}
        <div class="mt-3 text-center">
            <button type="button" onclick="document.getElementById('modal-rechazo').style.display='flex'"
                    style="background:none;border:none;color:#999;font-size:0.85em;cursor:pointer;
                           text-decoration:underline;padding:4px 8px;">
                <i class="fas fa-times-circle mr-1"></i> {{ trans('firmadoc-dont-want-to-sign') }}
            </button>
        </div>

        {# MODAL DE RECHAZO #}
        <div id="modal-rechazo"
             style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
                    background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;">
            <div style="background:#fff;border-radius:12px;padding:28px;max-width:420px;width:90%;
                        box-shadow:0 8px 32px rgba(0,0,0,0.2);">
                <h5 style="margin-bottom:16px;color:#c0392b;">
                    <i class="fas fa-times-circle mr-2"></i> {{ trans('firmadoc-reject-document') }}
                </h5>
                <p class="text-muted small mb-3">
                    {{ trans('firmadoc-reject-reason-help') }}
                </p>
                <form method="post" id="formRechazo">
                    <input type="hidden" name="action" value="rechazar">
                    <input type="text" name="rechazo_nombre" required
                           placeholder="{{ trans('firmadoc-your-full-name-required') }}"
                           style="width:100%;border:1px solid #ddd;border-radius:8px;
                                  padding:10px;font-size:0.9em;margin-bottom:10px;
                                  box-sizing:border-box;">
                    <textarea name="motivo_rechazo" rows="3" required
                              placeholder="{{ trans('firmadoc-reject-reason-required') }}"
                              style="width:100%;border:1px solid #ddd;border-radius:8px;
                                     padding:10px;font-size:0.9em;resize:vertical;
                                     box-sizing:border-box;"></textarea>
                    <div class="mt-3 d-flex" style="gap:10px;">
                        <button type="button"
                                onclick="document.getElementById('modal-rechazo').style.display='none'"
                                style="flex:1;padding:10px;border:1px solid #ddd;border-radius:8px;
                                       background:#f8f9fa;cursor:pointer;font-size:0.9em;">
                            {{ trans('firmadoc-cancel') }}
                        </button>
                        <button type="submit"
                                style="flex:1;padding:10px;border:none;border-radius:8px;
                                       background:#c0392b;color:#fff;cursor:pointer;
                                       font-size:0.9em;font-weight:600;">
                            <i class="fas fa-times mr-1"></i> {{ trans('firmadoc-confirm-reject') }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
        {% endif %}

        {# PIE #}
        <div class="mt-4 text-center text-muted small">
            <i class="fas fa-lock mr-1"></i> {{ trans('firmadoc-secure-signature') }}
        </div>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js"></script>
{% if fsc.config.modo_certificado %}
<script>
SupportDialog.enableSupportDialog(false);
SupportDialog.enableLoadingDialog(false);
AutoScript.cargarAppAfirma();
</script>
{% endif %}
<script>
// Translation strings for JavaScript
var FD_TRANS = {
    alertEnterName: {{ trans('firmadoc-alert-enter-name') | json_encode | raw }},
    alertDrawSignature: {{ trans('firmadoc-alert-draw-signature') | json_encode | raw }},
    alertSelectCertificate: {{ trans('firmadoc-alert-select-certificate') | json_encode | raw }},
    startingAutofirma: {{ trans('firmadoc-starting-autofirma') | json_encode | raw }},
    couldNotLoadClient: {{ trans('firmadoc-could-not-load-client') | json_encode | raw }},
    retry: {{ trans('firmadoc-retry') | json_encode | raw }},
    selectionCancelled: {{ trans('firmadoc-selection-cancelled') | json_encode | raw }},
    selectCertificate: {{ trans('firmadoc-select-certificate') | json_encode | raw }},
    errorAutofirma: {{ trans('firmadoc-error-autofirma') | json_encode | raw }},
    unexpectedError: {{ trans('firmadoc-unexpected-error') | json_encode | raw }},
    certificateSelected: {{ trans('firmadoc-certificate-selected') | json_encode | raw }},
    signedWithCertificate: {{ trans('firmadoc-signed-with-certificate') | json_encode | raw }},
    needAutofirma: {{ trans('firmadoc-need-autofirma') | json_encode | raw }},
    download: {{ trans('firmadoc-download') | json_encode | raw }},
    configNeededTitle: {{ trans('firmadoc-config-needed-title') | json_encode | raw }},
    configNeededDesc: {{ trans('firmadoc-config-needed-desc') | json_encode | raw }},
    alreadyInstalledRetry: {{ trans('firmadoc-already-installed-retry') | json_encode | raw }},
    changeMethodWarning: {{ trans('firmadoc-change-method-warning') | json_encode | raw }},
    certFieldLocked: {{ trans('firmadoc-cert-field-locked') | json_encode | raw }},
