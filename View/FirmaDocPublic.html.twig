function procesarCertificadoSeleccionado(certB64, estadoDiv, infoDiv) {
    try {
        const certInfo = parsearCertificado(certB64);

        certSeleccionado = {
            cert: certB64,
            nombre: certInfo.nombre,
            nif: certInfo.nif,
            expiry: certInfo.expiry
        };

        const nombreInput = document.getElementById('firma_nombre_input');
        const nifInput    = document.getElementById('firma_nif_input');

        if (nombreInput && certInfo.nombre) {
            nombreInput.value = certInfo.nombre;
            nombreInput.readOnly = true;
            nombreInput.style.backgroundColor = '#e9ecef';
            nombreInput.style.borderColor = '#ced4da';
            nombreInput.style.cursor = 'not-allowed';
            nombreInput.title = FD_TRANS.certFieldLocked;
        }
        if (nifInput && certInfo.nif) {
            nifInput.value = certInfo.nif;
            nifInput.readOnly = true;
            nifInput.style.backgroundColor = '#e9ecef';
            nifInput.style.borderColor = '#ced4da';
            nifInput.style.cursor = 'not-allowed';
            nifInput.title = FD_TRANS.certFieldLocked;
        }

        document.getElementById('firma_certificado_data').value = JSON.stringify({
            tipo: 'autofirma',
            cert: certB64,
            nombre: certInfo.nombre,
            nif: certInfo.nif,
            expiry: certInfo.expiry
        });

        document.getElementById('cert-nombre-display').textContent = certInfo.nombre || FD_TRANS.certificateSelected;
        document.getElementById('cert-nif-display').textContent    = certInfo.nif   || '—';
        document.getElementById('cert-expiry-display').textContent = certInfo.expiry || '—';

        estadoDiv.style.display = 'none';
        infoDiv.style.display   = 'block';

    } catch(e) {
        certSeleccionado = { cert: certB64, nombre: '', nif: '', expiry: '' };
        document.getElementById('firma_certificado_data').value = JSON.stringify({
            tipo: 'autofirma', cert: certB64
        });
        document.getElementById('cert-nombre-display').textContent = FD_TRANS.certificateSelected;
        document.getElementById('cert-nif-display').textContent    = '—';
        document.getElementById('cert-expiry-display').textContent = '—';
        estadoDiv.style.display = 'none';
        infoDiv.style.display   = 'block';
    }
}

function parsearCertificado(certB64) {
    try {
        const binary = atob(certB64);
        const buf = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) buf[i] = binary.charCodeAt(i);

        function readLen(buf, pos) {
            if (buf[pos] < 0x80) return { len: buf[pos], next: pos + 1 };
            const n = buf[pos] & 0x7F;
            let len = 0;
            for (let i = 0; i < n; i++) len = (len << 8) | buf[pos + 1 + i];
            return { len, next: pos + 1 + n };
        }

        function readNode(buf, pos) {
            const tag = buf[pos];
            const { len, next } = readLen(buf, pos + 1);
            return { tag, len, start: next, end: next + len };
        }

        function children(buf, start, end) {
            const result = [];
            let pos = start;
            while (pos < end) {
                const node = readNode(buf, pos);
                result.push(node);
                pos = node.end;
            }
            return result;
        }

        function readOID(buf, start, len) {
            const bytes = buf.slice(start, start + len);
            let oid = Math.floor(bytes[0] / 40) + '.' + (bytes[0] % 40);
            let val = 0;
            for (let i = 1; i < bytes.length; i++) {
                val = (val << 7) | (bytes[i] & 0x7F);
                if (!(bytes[i] & 0x80)) { oid += '.' + val; val = 0; }
            }
            return oid;
        }

        function readStr(buf, tag, start, len) {
            const bytes = buf.slice(start, start + len);
            if (tag === 0x1E) {
                let s = '';
                for (let i = 0; i < bytes.length - 1; i += 2)
                    s += String.fromCharCode((bytes[i] << 8) | bytes[i+1]);
                return s;
            }
            let s = '';
            for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
            return s;
        }

        function readDate(buf, tag, start, len) {
            let s = '';
            for (let i = 0; i < len; i++) s += String.fromCharCode(buf[start + i]);
            try {
                if (tag === 0x17) {
                    const yr = parseInt(s.substr(0,2));
                    const year = yr >= 50 ? 1900+yr : 2000+yr;
                    return year + '-' + s.substr(2,2) + '-' + s.substr(4,2);
                } else {
                    return s.substr(0,4) + '-' + s.substr(4,2) + '-' + s.substr(6,2);
                }
            } catch(e) { return ''; }
        }

        const OID_CN      = '2.5.4.3';
        const OID_SERIAL  = '2.5.4.5';
        const OID_GIVEN   = '2.5.4.42';
        const OID_SURNAME = '2.5.4.4';

        const root     = readNode(buf, 0);
        const tbsKids  = children(buf, root.start, root.end);
        const tbs      = tbsKids[0];
        const tbsItems = children(buf, tbs.start, tbs.end);

        let validity = null, subject = null;
        let idx = 0;
        if (tbsItems[0] && tbsItems[0].tag === 0xA0) idx = 1;
        if (tbsItems[idx+3]) validity = tbsItems[idx+3];
        if (tbsItems[idx+4]) subject  = tbsItems[idx+4];

        let expiry = '';
        if (validity) {
            const valKids = children(buf, validity.start, validity.end);
            if (valKids[1]) {
                expiry = readDate(buf, valKids[1].tag, valKids[1].start, valKids[1].len);
            }
        }

        let cn = '', serialNum = '', givenName = '', surname = '';
        const extraOIDs = {};

        if (subject) {
            const rdns = children(buf, subject.start, subject.end);
            for (const rdn of rdns) {
                const attrs = children(buf, rdn.start, rdn.end);
                for (const attr of attrs) {
                    const attrKids = children(buf, attr.start, attr.end);
                    if (attrKids.length < 2) continue;
                    const oidNode = attrKids[0];
                    const valNode = attrKids[1];
                    const oid = readOID(buf, oidNode.start, oidNode.len);
                    const val = readStr(buf, valNode.tag, valNode.start, valNode.len).trim();
                    if (oid === OID_CN)      cn         = val;
                    if (oid === OID_SERIAL)  serialNum  = val;
                    if (oid === OID_GIVEN)   givenName  = val;
                    if (oid === OID_SURNAME) surname    = val;
                    extraOIDs[oid] = val;
                }
            }
        }

        let nif = '';
        if (serialNum) {
            const m1 = serialNum.match(/IDCE[SC]-?([0-9A-Z]{8,9})/i);
            if (m1) nif = m1[1];
            else {
                const m2 = serialNum.match(/(\d{8}[A-Z])/);
                if (m2) nif = m2[1];
                else {
                    const m3 = serialNum.match(/([XYZ]\d{7}[A-Z])/);
                    if (m3) nif = m3[1];
                    else nif = serialNum;
                }
            }
        }

        let nombre = '';
        if (givenName && surname) {
            nombre = (givenName + ' ' + surname).trim();
        } else if (cn) {
            nombre = cn.replace(/-\s*[0-9A-Z]{8,9}\s*$/, '').replace(/,\s*/, ' ').trim();
            if (cn.includes(',')) {
                const parts = cn.split(',');
                if (parts.length === 2) nombre = parts[1].trim() + ' ' + parts[0].trim();
            }
        }

        return { nombre, nif, expiry };
    } catch(e) {
        return { nombre: '', nif: '', expiry: '' };
    }
}

window.addEventListener('resize', () => {
    if (canvas) { ajustarCanvas(); }
});
</script>
</body>
</html>
