// === CAMBIO DE MODO ===
function _desbloquearCamposIdentidad() {
    const nombreInput = document.getElementById('firma_nombre_input');
    const nifInput    = document.getElementById('firma_nif_input');
    [nombreInput, nifInput].forEach(function(el) {
        if (!el) return;
        el.readOnly = false;
        el.style.backgroundColor = '';
        el.style.borderColor = '';
        el.style.cursor = '';
        el.title = '';
    });
}

function _anularCertificado() {
    certSeleccionado = null;

    var estadoDiv = document.getElementById('cert-estado');
    var infoDiv   = document.getElementById('cert-info');
    if (estadoDiv) {
        estadoDiv.innerHTML =
            '<i class="fas fa-id-card fa-2x text-muted mb-2 d-block"></i>' +
            '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">' +
            '<i class="fas fa-search mr-1"></i> ' + FD_TRANS.selectCertificate + '</button>' +
            '<p class="text-muted small mt-2 mb-0">' + FD_TRANS.needAutofirma + ' ' +
            '<a href="https://firmaelectronica.gob.es/Home/Descargas.html" target="_blank">' + FD_TRANS.download + '</a></p>';
        estadoDiv.style.display = 'block';
    }
    if (infoDiv) infoDiv.style.display = 'none';

    var nombreInput = document.getElementById('firma_nombre_input');
    var nifInput    = document.getElementById('firma_nif_input');
    if (nombreInput) nombreInput.value = '';
    if (nifInput)    nifInput.value    = '';
    _desbloquearCamposIdentidad();

    var certHidden = document.getElementById('firma_certificado_data');
    if (certHidden) certHidden.value = '';
}

function cambiarModo(modo, tabEl) {
    if (certSeleccionado && modo !== 'certificado') {
        if (!confirm(FD_TRANS.changeMethodWarning)) return;
        _anularCertificado();
    }
    if (modo === 'certificado' && !certSeleccionado) {
        _desbloquearCamposIdentidad();
    }
    modoActual = modo;
    document.querySelectorAll('.tab-modo').forEach(function(t) { t.classList.remove('activo'); });
    document.querySelectorAll('.panel-modo').forEach(function(p) { p.classList.add('d-none'); });
    if (tabEl) tabEl.classList.add('activo');
    document.getElementById('panel-' + modo).classList.remove('d-none');
}

// === PREPARAR FIRMA ANTES DE ENVIAR ===
function prepararFirma() {
    const nombreInput = document.getElementById('firma_nombre_input');
    if (!nombreInput || !nombreInput.value.trim()) {
        alert(FD_TRANS.alertEnterName);
        return false;
    }

    const imagenInput = document.getElementById('firma_imagen');

    if (modoActual === 'manuscrita' && canvas) {
        const pixelData = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
        const hayFirma = Array.from(pixelData).some((v, i) => i % 4 === 3 && v > 0);
        if (!hayFirma) {
            alert(FD_TRANS.alertDrawSignature);
            return false;
        }
        imagenInput.value = canvas.toDataURL('image/png');
    } else if (modoActual === 'tipografica') {
        const nombre = nombreInput.value.trim();
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = 400;
        tempCanvas.height = 100;
        const tCtx = tempCanvas.getContext('2d');
        tCtx.fillStyle = '#fff';
        tCtx.fillRect(0, 0, 400, 100);
        tCtx.font = '60px Dancing Script';
        tCtx.fillStyle = '#1a4a8a';
        tCtx.textBaseline = 'middle';
        tCtx.fillText(nombre, 20, 50);
        imagenInput.value = tempCanvas.toDataURL('image/png');
    } else if (modoActual === 'certificado') {
        const certData = document.getElementById('firma_certificado_data').value;
        if (!certData) {
            alert(FD_TRANS.alertSelectCertificate);
            return false;
        }
        const nombre = nombreInput.value.trim();
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = 400;
        tempCanvas.height = 100;
        const tCtx = tempCanvas.getContext('2d');
        tCtx.fillStyle = '#f0f4ff';
        tCtx.fillRect(0, 0, 400, 100);
        tCtx.font = 'bold 14px sans-serif';
        tCtx.fillStyle = '#2c5aa0';
        tCtx.fillText(FD_TRANS.signedWithCertificate, 15, 30);
        tCtx.font = '13px sans-serif';
        tCtx.fillStyle = '#333';
        tCtx.fillText(nombre, 15, 55);
        tCtx.font = '11px sans-serif';
        tCtx.fillStyle = '#666';
        tCtx.fillText(FD_TRANS.nifDni + ': ' + (document.getElementById('cert-nif-display').textContent || ''), 15, 78);
        imagenInput.value = tempCanvas.toDataURL('image/png');
    }

    return true;
}

// === CERTIFICADO DIGITAL CON AUTOFIRMA ===
let certSeleccionado = null;

function iniciarAutofirma() {
    const estadoDiv = document.getElementById('cert-estado');
    const infoDiv   = document.getElementById('cert-info');

    // En móvil: comprobar si AutoFirma puede responder antes de lanzar
    if (esMobile) {
        // Intentar lanzar — si falla en 3 segundos, mostrar aviso de descarga
        var lanzado = false;
        var timeout = setTimeout(function() {
            if (!lanzado) {
                _mostrarErrorCertificado(estadoDiv, infoDiv);
            }
        }, 3000);

        // Escuchar si el usuario vuelve a la página (la app se abrió)
        var onVuelta = function() {
            lanzado = true;
            clearTimeout(timeout);
            document.removeEventListener('visibilitychange', onVuelta);
        };
        document.addEventListener('visibilitychange', onVuelta);
    }

    if (typeof AutoScript === 'undefined') {
        estadoDiv.innerHTML =
            '<i class="fas fa-exclamation-triangle fa-2x text-danger mb-2 d-block"></i>' +
            '<p class="text-danger small mb-2">' + FD_TRANS.couldNotLoadClient + '</p>' +
            '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">' +
            '<i class="fas fa-redo mr-1"></i> ' + FD_TRANS.retry + '</button>';
        return;
    }

    estadoDiv.innerHTML =
        '<i class="fas fa-circle-notch fa-spin fa-2x text-primary mb-2 d-block"></i>' +
        '<p class="text-muted small mb-0">' + FD_TRANS.startingAutofirma + '</p>';

    _verificarCertYLanzar(estadoDiv, infoDiv);
}

function _verificarCertYLanzar(estadoDiv, infoDiv) {
    _lanzarSelectCertificate(estadoDiv, infoDiv);
}

function _lanzarSelectCertificate(estadoDiv, infoDiv) {
    try {
        AutoScript.selectCertificate(
            null,
            function(certB64) {
                procesarCertificadoSeleccionado(certB64, estadoDiv, infoDiv);
            },
            function(type, message) {
                const esCancelado = (type && (type.includes('Cancel') || type.includes('cancel')))
                    || (message && message.toLowerCase().includes('cancel'))
                    || (message && message.toLowerCase().includes('cancelad'));

                const esConexion = type && (
                    type.includes('ApplicationNotFoundException') ||
                    type.includes('IOException') ||
                    type.includes('TimeoutException') ||
                    type.includes('CONNECTION_ERROR')
                );

                if (esCancelado) {
                    estadoDiv.innerHTML =
                        '<p class="text-muted small mb-2">' + FD_TRANS.selectionCancelled + '</p>'
                        + '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">'
                        + '<i class="fas fa-id-card mr-1"></i> ' + FD_TRANS.selectCertificate + '</button>';
                    infoDiv.style.display = 'none';

                } else if (esConexion) {
                    _mostrarErrorCertificado(estadoDiv, infoDiv);

                } else {
                    estadoDiv.innerHTML =
                        '<p class="text-danger small mb-2">' + FD_TRANS.errorAutofirma + '<br>'
                        + '<small><code>' + (type || '') + '</code><br>' + (message || '') + '</small></p>'
                        + '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">'
                        + '<i class="fas fa-redo mr-1"></i> ' + FD_TRANS.retry + '</button>';
                    infoDiv.style.display = 'none';
                }
            }
        );
    } catch(e) {
        estadoDiv.innerHTML =
            '<p class="text-danger small mb-2">' + FD_TRANS.unexpectedError + ' ' + e.message + '</p>'
            + '<button type="button" class="btn btn-outline-secondary btn-sm" onclick="iniciarAutofirma()">'
            + '<i class="fas fa-redo mr-1"></i> ' + FD_TRANS.retry + '</button>';
    }
}

