<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ fsc.firma.codigo_doc ?? 'Firma de documento' }} — Firma electrónica</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        body { background: #f5f6fa; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
        .firma-card { max-width: 680px; margin: 30px auto; background: #fff; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.10); overflow: hidden; }
        .firma-header { background: linear-gradient(135deg, #1a7a4a 0%, #2ecc71 100%); color: #fff; padding: 28px 32px 20px; }
        .firma-header h1 { font-size: 1.4rem; font-weight: 700; margin: 0 0 4px; }
        .firma-header p { margin: 0; opacity: 0.85; font-size: 0.95rem; }
        .firma-body { padding: 28px 32px; }
        #canvas-firma { border: 2px dashed #dee2e6; border-radius: 8px; cursor: crosshair; background: #fafafa; touch-action: none; width: 100%; }
        #canvas-firma.activo { border-color: #1a7a4a; background: #fff; }
        .tab-modo { cursor: pointer; padding: 10px 20px; border-radius: 8px 8px 0 0; border: 1px solid #dee2e6; border-bottom: none; background: #f8f9fa; font-size: 0.9rem; }
        .tab-modo.activo { background: #fff; font-weight: 600; color: #1a7a4a; border-bottom: 1px solid #fff; margin-bottom: -1px; }
        .panel-modo { border: 1px solid #dee2e6; border-radius: 0 8px 8px 8px; padding: 20px; background: #fff; }
        .firma-tipografica-preview { font-family: 'Dancing Script', cursive; font-size: 2.5rem; color: #1a4a8a; min-height: 80px; border-bottom: 2px solid #dee2e6; text-align: center; padding: 10px; letter-spacing: 2px; }
        .btn-firmar { background: linear-gradient(135deg, #1a7a4a, #2ecc71); border: none; color: #fff; padding: 14px 40px; font-size: 1.1rem; font-weight: 600; border-radius: 8px; width: 100%; margin-top: 10px; }
        .btn-firmar:hover { opacity: 0.9; color: #fff; }
        .doc-info { background: #f8f9fa; border-radius: 8px; padding: 14px 18px; margin-bottom: 20px; font-size: 0.9rem; }
        .doc-info strong { color: #333; }
        .alerta { border-radius: 8px; padding: 16px 20px; margin-bottom: 20px; }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&display=swap" rel="stylesheet">
    {% if fsc.config.modo_certificado %}
    <script src="{{ fsc.urlBase }}/Plugins/FirmaDoc/Assets/autoscript.js?v=2.63"></script>
    {% endif %}
</head>
<body>

<div class="firma-card">

    {# CABECERA #}
    <div class="firma-header">
        <h1><i class="fas fa-signature mr-2"></i> Firma electrónica</h1>
        <p>Por favor, revisa el documento y fírmalo a continuación</p>
    </div>

    <div class="firma-body">

        {# MENSAJE DE ESTADO #}
        {% if fsc.mensaje %}
        <div class="alerta alert-{% if fsc.mensajeTipo == 'success' %}success{% elseif fsc.mensajeTipo == 'danger' %}danger{% elseif fsc.mensajeTipo == 'warning' %}warning{% else %}info{% endif %}">
            {% if fsc.mensajeTipo == 'success' %}
                <i class="fas fa-check-circle mr-2"></i>
            {% elseif fsc.mensajeTipo == 'danger' %}
                <i class="fas fa-times-circle mr-2"></i>
            {% else %}
                <i class="fas fa-info-circle mr-2"></i>
            {% endif %}
            {{ fsc.mensaje }}
        </div>
        {% endif %}

        {# PROGRESO MULTI-FIRMANTE — visible siempre que haya más de 1 firmante #}
        {% if fsc.firmantesTotal > 1 %}
        <div style="background:#f8f9fa;border-radius:8px;padding:12px 16px;margin-bottom:16px;border:1px solid #dee2e6">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <small class="font-weight-bold text-secondary">
              <i class="fas fa-users mr-1"></i>Proceso de firma
            </small>
            <small class="text-secondary">
              {{ fsc.firmantesHanFirmado }} de {{ fsc.firmantesTotal }} firmantes
            </small>
          </div>
          <div style="background:#dee2e6;border-radius:4px;height:8px;overflow:hidden">
            {% set pct = fsc.firmantesTotal > 0 ? (fsc.firmantesHanFirmado / fsc.firmantesTotal * 100)|round : 0 %}
            <div style="background:#28a745;height:100%;width:{{ pct }}%;transition:width .4s;min-width:{{ pct > 0 ? '4px' : '0' }}"></div>
          </div>
        </div>
        {% endif %}

        {# INFO DEL DOCUMENTO + VISOR PDF INLINE #}
        {# En multi-firmante parcial: ocultar el visor hasta que firmen todos o mostrar aviso #}
        {% if fsc.firma %}
        <div class="doc-info">
            <div class="row align-items-center">
                <div class="col-6">
                    <strong>Documento:</strong><br>
                    {{ fsc.firma.tipo_doc|capitalize }} {{ fsc.firma.codigo_doc }}
                </div>
                <div class="col-6">
                    {% if fsc.firma.estado == 'firmado' %}
                    <strong>Firmado el:</strong><br>
                    {{ fsc.firma.fecha_firma }}
                    {% elseif fsc.firma.estado == 'cancelado' %}
                    <strong>Estado:</strong><br>
                    <span style="color:#c0392b;font-weight:600;">Rechazado</span>
                    {% else %}
                    <strong>Válido hasta:</strong><br>
                    {{ fsc.firma.fecha_expiracion }}
                    {% endif %}
                </div>
            </div>

            {# Visor PDF — se muestra siempre (sin firmas si el proceso está en curso) #}
            {% set esMultiFirmanteParcial = fsc.firmantesTotal > 1 and fsc.firma.estado != 'firmado' %}
            {% if fsc.linkDocumento
               and fsc.firma.estado not in ['cancelado', 'expirado', 'anulado_mod']
               and (fsc.config.descarga_pdf == 'siempre'
                    or fsc.firma.estado == 'firmado'
                    or fsc.config.descarga_pdf == 'posfirma') %}

            {# Aviso legal cuando hay firmantes pendientes #}
            {% if esMultiFirmanteParcial %}
            <div style="background:#fff8e1;border:1px solid #ffe082;border-radius:6px;padding:10px 14px;margin-bottom:10px;font-size:0.85em;color:#5d4037">
              <i class="fas fa-info-circle mr-1" style="color:#f9a825"></i>
              <strong>Nota:</strong> El documento que se muestra a continuación corresponde al original sin firmas.
              Las firmas electrónicas se incorporarán al documento una vez que todos los firmantes hayan completado el proceso.
              El presente proceso de firma tiene plena validez jurídica conforme al Reglamento (UE) 910/2014 (eIDAS).
            </div>
            {% endif %}
            <div class="mt-3">
                <div id="pdf-toggle" onclick="togglePdf()"
                     style="background:#f0f4ff;border:1px solid #c8d8f8;border-radius:8px;
                            padding:10px 14px;cursor:pointer;display:flex;
                            justify-content:space-between;align-items:center;user-select:none;">
                    <span style="font-weight:600;color:#2c5aa0;">
                        <i class="fas fa-file-pdf mr-2" style="color:#e53935;"></i>
                        {% if fsc.firma.estado == 'firmado' %}
                            Ver documento firmado
                        {% elseif fsc.firmantesHanFirmado > 0 and fsc.firmantesTotal > 1 %}
                            Ver documento ({{ fsc.firmantesHanFirmado }}/{{ fsc.firmantesTotal }} firmas)
                        {% else %}
                            Ver documento antes de firmar
                        {% endif %}
                    </span>
                    <span id="pdf-toggle-icon" style="color:#2c5aa0;font-size:1.1em;">
                        <i class="fas fa-chevron-down"></i>
                    </span>
                </div>
                <div id="pdf-viewer" style="display:none;margin-top:6px;border-radius:8px;overflow:hidden;border:1px solid #c8d8f8;">
                    <iframe src="{{ fsc.linkDocumento }}#toolbar=1&navpanes=0&scrollbar=1"
                            style="width:100%;height:420px;border:none;display:block;"
                            title="Vista previa del documento">
                        <p>Tu navegador no soporta la vista previa.
                           <a href="{{ fsc.linkDocumento }}" target="_blank">Descarga el PDF aquí</a>.
                        </p>
                    </iframe>
                    <div style="background:#f8f9ff;padding:8px 12px;text-align:right;border-top:1px solid #e0e8ff;">
                        <a href="{{ fsc.linkDocumento }}" target="_blank"
                           style="font-size:0.82em;color:#2c5aa0;text-decoration:none;">
                            <i class="fas fa-external-link-alt mr-1"></i> Abrir en nueva pestaña
                        </a>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
        {% endif %}


        {# FORMULARIO DE FIRMA #}
        {% if fsc.tokenValido %}
        <form method="post" id="formFirma">
            <input type="hidden" name="action" value="firmar">
            <input type="hidden" name="firma_imagen" id="firma_imagen">
            <input type="hidden" name="firma_certificado_data" id="firma_certificado_data">

            {# TABS DE MODO #}
            {% set modos = [] %}
            {% if fsc.config.modo_manuscrita %} {% set modos = modos|merge(['manuscrita']) %} {% endif %}
            {% if fsc.config.modo_tipografica %} {% set modos = modos|merge(['tipografica']) %} {% endif %}
            {% if fsc.config.modo_certificado %} {% set modos = modos|merge(['certificado']) %} {% endif %}

            {% if modos|length > 1 %}
            <div class="d-flex mb-0 flex-wrap">
                {% if fsc.config.modo_manuscrita %}
                <div class="tab-modo activo" onclick="cambiarModo('manuscrita', this)">
                    <i class="fas fa-pen mr-1"></i> Firma manuscrita
                </div>
                {% endif %}
                {% if fsc.config.modo_tipografica %}
                <div class="tab-modo" onclick="cambiarModo('tipografica', this)">
                    <i class="fas fa-font mr-1"></i> Firma tipográfica
                </div>
                {% endif %}
                {% if fsc.config.modo_certificado %}
                <div class="tab-modo" onclick="cambiarModo('certificado', this)">
                    <i class="fas fa-id-card mr-1"></i> Certificado digital
                </div>
                {% endif %}
            </div>
            {% endif %}

            {# PANEL MANUSCRITA #}
            {% if fsc.config.modo_manuscrita %}
            <div class="panel-modo" id="panel-manuscrita">
                <p class="text-muted small mb-2">Dibuja tu firma en el recuadro:</p>
                <canvas id="canvas-firma" height="160"></canvas>
                <div class="mt-2 text-right">
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="limpiarCanvas()">
                        <i class="fas fa-eraser mr-1"></i> Borrar
                    </button>
                </div>
            </div>
            {% endif %}

            {# PANEL TIPOGRÁFICA #}
            {% if fsc.config.modo_tipografica %}
            <div class="panel-modo {% if fsc.config.modo_manuscrita %}d-none{% endif %}" id="panel-tipografica">
                <p class="text-muted small mb-2">Escribe tu nombre completo:</p>
                <input type="text" class="form-control mb-3" id="nombre-tipografico"
                    placeholder="Tu nombre completo"
                    oninput="actualizarFirmaTipografica(this.value)">
                <div class="firma-tipografica-preview" id="preview-tipografica"></div>
            </div>
            {% endif %}

            {# PANEL CERTIFICADO DIGITAL #}
            {% if fsc.config.modo_certificado %}
            <div class="panel-modo {% if fsc.config.modo_manuscrita or fsc.config.modo_tipografica %}d-none{% endif %}"
                 id="panel-certificado">
                <p class="text-muted small mb-2">
                    Firma con tu certificado electrónico instalado en el navegador
                    (DNIe, FNMT, Camerfirma, etc.).
                </p>
                <div id="cert-estado" style="padding:14px;border-radius:8px;background:#f8f9fa;
                     border:1px solid #dee2e6;text-align:center;">
                    <i class="fas fa-id-card fa-2x text-muted mb-2 d-block"></i>
                    <button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">
                        <i class="fas fa-search mr-1"></i> Seleccionar certificado
                    </button>
                    <p class="text-muted small mt-2 mb-0">
                        Necesitas tener <strong>AutoFirma</strong> instalado.
                        <a href="https://firmaelectronica.gob.es/Home/Descargas.html" target="_blank">Descargar</a>
                    </p>
                </div>
                <div id="cert-info" style="display:none;padding:14px;border-radius:8px;
                     background:#e8f5e9;border:1px solid #a5d6a7;">
                    <i class="fas fa-check-circle text-success mr-2"></i>
                    <strong id="cert-nombre-display"></strong><br>
                    <small class="text-muted">
                        NIF: <span id="cert-nif-display"></span> &nbsp;·&nbsp;
                        Válido hasta: <span id="cert-expiry-display"></span>
                    </small>
                    <br><br>
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="iniciarAutofirma()">
                        <i class="fas fa-sync mr-1"></i> Cambiar certificado
                    </button>
                </div>
            </div>
            {% endif %}

            {# CAMPOS ADICIONALES #}
            <div class="mt-3">
                <div class="form-group">
                    <label class="font-weight-bold small">Nombre completo <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="firma_nombre" id="firma_nombre_input"
                        placeholder="Nombre y apellidos" required>
                </div>

                {% if fsc.config.nif_modo != 'no' %}
                <div class="form-group">
                    <label class="font-weight-bold small">
                        NIF / DNI
                        {% if fsc.config.nif_modo == 'obligatorio' %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    <input type="text" class="form-control" name="firma_nif" id="firma_nif_input"
                        placeholder="12345678A"
                        {% if fsc.config.nif_modo == 'obligatorio' %}required{% endif %}>
                </div>
                {% endif %}

                {% if fsc.config.cargo_modo != 'no' %}
                <div class="form-group">
                    <label class="font-weight-bold small">
                        Cargo
                        {% if fsc.config.cargo_modo == 'obligatorio' %}<span class="text-danger">*</span>{% endif %}
                    </label>
                    <input type="text" class="form-control" name="firma_cargo"
                        placeholder="Director, Gerente..."
                        {% if fsc.config.cargo_modo == 'obligatorio' %}required{% endif %}>
                </div>
                {% endif %}

                {% if fsc.config.legal_url or fsc.config.legal_texto %}
                <div class="form-group">
                    <div class="custom-control custom-checkbox">
                        <input type="checkbox" class="custom-control-input" id="acepto_legal"
                            name="acepto_legal" value="1" required>
                        <label class="custom-control-label small" for="acepto_legal">
                            Acepto
                            {% if fsc.config.legal_url %}
                                <a href="{{ fsc.config.legal_url }}" target="_blank">el aviso legal</a>
                            {% else %}
                                el aviso legal
                            {% endif %}
                            y presto mi consentimiento para la firma electrónica de este documento.
                        </label>
                    </div>
                </div>
                {% endif %}

                {# OBSERVACIONES DEL FIRMANTE #}
                <div class="form-group mt-2">
                    <label class="small text-muted" for="observaciones_firmante">
                        <i class="fas fa-comment-alt mr-1"></i>
                        Observaciones <span class="text-muted">(opcional)</span>
                    </label>
                    <textarea id="observaciones_firmante" name="observaciones_firmante" rows="2"
                              placeholder="Añade cualquier comentario o condición antes de firmar..."
                              style="width:100%;border:1px solid #ddd;border-radius:8px;
                                     padding:10px;font-size:0.88em;resize:vertical;
                                     font-family:inherit;"></textarea>
                </div>
            </div>

            <button type="submit" class="btn btn-firmar" onclick="return prepararFirma()">
                <i class="fas fa-check-circle mr-2"></i> Firmar documento
            </button>
        </form>

        {# BOTÓN RECHAZAR #}
        <div class="mt-3 text-center">
            <button type="button" onclick="document.getElementById('modal-rechazo').style.display='flex'"
                    style="background:none;border:none;color:#999;font-size:0.85em;cursor:pointer;
                           text-decoration:underline;padding:4px 8px;">
                <i class="fas fa-times-circle mr-1"></i> No quiero firmar este documento
            </button>
        </div>

        {# MODAL DE RECHAZO #}
        <div id="modal-rechazo"
             style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;
                    background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;">
            <div style="background:#fff;border-radius:12px;padding:28px;max-width:420px;width:90%;
                        box-shadow:0 8px 32px rgba(0,0,0,0.2);">
                <h5 style="margin-bottom:16px;color:#c0392b;">
                    <i class="fas fa-times-circle mr-2"></i> Rechazar documento
                </h5>
                <p class="text-muted small mb-3">
                    Por favor indícanos el motivo para que podamos atenderte correctamente.
                </p>
                <form method="post" id="formRechazo">
                    <input type="hidden" name="action" value="rechazar">
                    <input type="text" name="rechazo_nombre" required
                           placeholder="Tu nombre completo *"
                           style="width:100%;border:1px solid #ddd;border-radius:8px;
                                  padding:10px;font-size:0.9em;margin-bottom:10px;
                                  box-sizing:border-box;">
                    <textarea name="motivo_rechazo" rows="3" required
                              placeholder="Motivo del rechazo *"
                              style="width:100%;border:1px solid #ddd;border-radius:8px;
                                     padding:10px;font-size:0.9em;resize:vertical;
                                     box-sizing:border-box;"></textarea>
                    <div class="mt-3 d-flex" style="gap:10px;">
                        <button type="button"
                                onclick="document.getElementById('modal-rechazo').style.display='none'"
                                style="flex:1;padding:10px;border:1px solid #ddd;border-radius:8px;
                                       background:#f8f9fa;cursor:pointer;font-size:0.9em;">
                            Cancelar
                        </button>
                        <button type="submit"
                                style="flex:1;padding:10px;border:none;border-radius:8px;
                                       background:#c0392b;color:#fff;cursor:pointer;
                                       font-size:0.9em;font-weight:600;">
                            <i class="fas fa-times mr-1"></i> Confirmar rechazo
                        </button>
                    </div>
                </form>
            </div>
        </div>
        {% endif %}

        {# PIE #}
        <div class="mt-4 text-center text-muted small">
            <i class="fas fa-lock mr-1"></i> Firma electrónica segura
        </div>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js"></script>
{% if fsc.config.modo_certificado %}
<script>
// Desactivar el diálogo de soporte propio de AutoScript para gestionar nosotros los errores
SupportDialog.enableSupportDialog(false);
SupportDialog.enableLoadingDialog(false);
// Inicializar AutoFirma al cargar la página (§6.1 del Manual del Integrador v1.9)
AutoScript.cargarAppAfirma();
</script>
{% endif %}
<script>
// === VISOR PDF INLINE ===
function togglePdf() {
    const viewer = document.getElementById('pdf-viewer');
    const icon   = document.getElementById('pdf-toggle-icon');
    const open   = viewer.style.display === 'none';
    viewer.style.display = open ? 'block' : 'none';
    icon.innerHTML = open
        ? '<i class="fas fa-chevron-up"></i>'
        : '<i class="fas fa-chevron-down"></i>';
}

// === PAD DE FIRMA MANUSCRITA ===
const canvas = document.getElementById('canvas-firma');
let ctx, dibujando = false, modoActual = '{% if fsc.config.modo_manuscrita %}manuscrita{% elseif fsc.config.modo_tipografica %}tipografica{% else %}certificado{% endif %}';

if (canvas) {
    ctx = canvas.getContext('2d');
    ctx.strokeStyle = '#1a1a2e';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ajustarCanvas();

    canvas.addEventListener('mousedown', iniciarDibujo);
    canvas.addEventListener('mousemove', dibujar);
    canvas.addEventListener('mouseup', () => dibujando = false);
    canvas.addEventListener('mouseleave', () => dibujando = false);
    canvas.addEventListener('touchstart', e => { e.preventDefault(); iniciarDibujo(e.touches[0]); }, {passive: false});
    canvas.addEventListener('touchmove', e => { e.preventDefault(); dibujar(e.touches[0]); }, {passive: false});
    canvas.addEventListener('touchend', () => dibujando = false);
}

function ajustarCanvas() {
    const w = canvas.parentElement.clientWidth - 40;
    canvas.width = w;
    ctx.strokeStyle = '#1a1a2e';
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
}

function getPosicion(e) {
    const rect = canvas.getBoundingClientRect();
    return {
        x: (e.clientX - rect.left) * (canvas.width / rect.width),
        y: (e.clientY - rect.top) * (canvas.height / rect.height)
    };
}

function iniciarDibujo(e) {
    dibujando = true;
    canvas.classList.add('activo');
    const pos = getPosicion(e);
    ctx.beginPath();
    ctx.moveTo(pos.x, pos.y);
}

function dibujar(e) {
    if (!dibujando) return;
    const pos = getPosicion(e);
    ctx.lineTo(pos.x, pos.y);
    ctx.stroke();
}

function limpiarCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    canvas.classList.remove('activo');
}

// === FIRMA TIPOGRÁFICA ===
function actualizarFirmaTipografica(nombre) {
    const preview = document.getElementById('preview-tipografica');
    if (preview) preview.textContent = nombre;
    const input = document.getElementById('firma_nombre_input');
    if (input && !input.value) input.value = nombre;
}

// === CAMBIO DE MODO ===
function _desbloquearCamposIdentidad() {
    const nombreInput = document.getElementById('firma_nombre_input');
    const nifInput    = document.getElementById('firma_nif_input');
    [nombreInput, nifInput].forEach(function(el) {
        if (!el) return;
        el.readOnly = false;
        el.style.backgroundColor = '';
        el.style.borderColor = '';
        el.style.cursor = '';
        el.title = '';
    });
}

function _anularCertificado() {
    certSeleccionado = null;

    // Resetear panel certificado al estado inicial
    const estadoDiv = document.getElementById('cert-estado');
    const infoDiv   = document.getElementById('cert-info');
    if (estadoDiv) {
        estadoDiv.innerHTML =
            '<i class="fas fa-id-card fa-2x text-muted mb-2 d-block"></i>' +
            '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">' +
            '<i class="fas fa-search mr-1"></i> Seleccionar certificado</button>' +
            '<p class="text-muted small mt-2 mb-0">Necesitas tener <strong>AutoFirma</strong> instalado. ' +
            '<a href="https://firmaelectronica.gob.es/Home/Descargas.html" target="_blank">Descargar</a></p>';
        estadoDiv.style.display = 'block';
    }
    if (infoDiv) infoDiv.style.display = 'none';

    // Limpiar campos de identidad
    const nombreInput = document.getElementById('firma_nombre_input');
    const nifInput    = document.getElementById('firma_nif_input');
    if (nombreInput) nombreInput.value = '';
    if (nifInput)    nifInput.value    = '';
    _desbloquearCamposIdentidad();

    // Limpiar campo hidden del certificado
    const certHidden = document.getElementById('firma_certificado_data');
    if (certHidden) certHidden.value = '';
}

function cambiarModo(modo, tabEl) {
    if (certSeleccionado && modo !== 'certificado') {
        var msg = 'Al cambiar el m\u00e9todo de firma, el certificado digital previamente seleccionado de ' + (certSeleccionado.nombre || 'este titular') + ' se anular\u00e1. Si desea volver a la firma por certificado digital deber\u00e1 seleccionar el certificado.';
        if (!confirm(msg)) return;
        _anularCertificado();
    }
    if (modo === 'certificado' && !certSeleccionado) {
        _desbloquearCamposIdentidad();
    }
    modoActual = modo;
    document.querySelectorAll('.tab-modo').forEach(function(t) { t.classList.remove('activo'); });
    document.querySelectorAll('.panel-modo').forEach(function(p) { p.classList.add('d-none'); });
    if (tabEl) tabEl.classList.add('activo');
    document.getElementById('panel-' + modo).classList.remove('d-none');
}

// === PREPARAR FIRMA ANTES DE ENVIAR ===
function prepararFirma() {
    const nombreInput = document.getElementById('firma_nombre_input');
    if (!nombreInput || !nombreInput.value.trim()) {
        alert('Por favor, introduce tu nombre completo.');
        return false;
    }

    const imagenInput = document.getElementById('firma_imagen');

    if (modoActual === 'manuscrita' && canvas) {
        const pixelData = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
        const hayFirma = Array.from(pixelData).some((v, i) => i % 4 === 3 && v > 0);
        if (!hayFirma) {
            alert('Por favor, dibuja tu firma en el recuadro.');
            return false;
        }
        imagenInput.value = canvas.toDataURL('image/png');
    } else if (modoActual === 'tipografica') {
        const nombre = nombreInput.value.trim();
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = 400;
        tempCanvas.height = 100;
        const tCtx = tempCanvas.getContext('2d');
        tCtx.fillStyle = '#fff';
        tCtx.fillRect(0, 0, 400, 100);
        tCtx.font = '60px Dancing Script';
        tCtx.fillStyle = '#1a4a8a';
        tCtx.textBaseline = 'middle';
        tCtx.fillText(nombre, 20, 50);
        imagenInput.value = tempCanvas.toDataURL('image/png');
    } else if (modoActual === 'certificado') {
        const certData = document.getElementById('firma_certificado_data').value;
        if (!certData) {
            alert('Por favor, selecciona tu certificado digital antes de firmar.');
            return false;
        }
        // Generar imagen representativa del certificado
        const nombre = nombreInput.value.trim();
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = 400;
        tempCanvas.height = 100;
        const tCtx = tempCanvas.getContext('2d');
        tCtx.fillStyle = '#f0f4ff';
        tCtx.fillRect(0, 0, 400, 100);
        tCtx.font = 'bold 14px sans-serif';
        tCtx.fillStyle = '#2c5aa0';
        tCtx.fillText('✓ Firmado con certificado digital', 15, 30);
        tCtx.font = '13px sans-serif';
        tCtx.fillStyle = '#333';
        tCtx.fillText(nombre, 15, 55);
        tCtx.font = '11px sans-serif';
        tCtx.fillStyle = '#666';
        tCtx.fillText('NIF: ' + (document.getElementById('cert-nif-display').textContent || ''), 15, 78);
        imagenInput.value = tempCanvas.toDataURL('image/png');
    }

    return true;
}

// === CERTIFICADO DIGITAL CON AUTOFIRMA ===
let certSeleccionado = null; // { cert: base64DER, nombre, nif, expiry }

function iniciarAutofirma() {
    const estadoDiv = document.getElementById('cert-estado');
    const infoDiv   = document.getElementById('cert-info');

    if (typeof AutoScript === 'undefined') {
        estadoDiv.innerHTML =
            '<i class="fas fa-exclamation-triangle fa-2x text-danger mb-2 d-block"></i>' +
            '<p class="text-danger small mb-2">No se pudo cargar el cliente de firma.</p>' +
            '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">' +
            '<i class="fas fa-redo mr-1"></i> Reintentar</button>';
        return;
    }

    estadoDiv.innerHTML =
        '<i class="fas fa-circle-notch fa-spin fa-2x text-primary mb-2 d-block"></i>' +
        '<p class="text-muted small mb-0">Iniciando AutoFirma...</p>';

    // Verificar primero si el certificado SSL de AutoFirma está aceptado en este navegador.
    // AutoFirma escucha en wss://127.0.0.1:PUERTO — el navegador rechaza silenciosamente
    // el WebSocket si el cert autofirmado no ha sido aceptado antes, haciendo que AutoFirma
    // arranque y se cierre sin poder comunicarse.
    // La solución es intentar un fetch HTTPS a 127.0.0.1 primero para detectar el problema.
    _verificarCertYLanzar(estadoDiv, infoDiv);
}

function _verificarCertYLanzar(estadoDiv, infoDiv) {
    _lanzarSelectCertificate(estadoDiv, infoDiv);
}

function _lanzarSelectCertificate(estadoDiv, infoDiv) {
    console.log('[FirmaDoc] Llamando a AutoScript.selectCertificate...');
    try {
        AutoScript.selectCertificate(
            null,
            function(certB64) {
                console.log('[FirmaDoc] SUCCESS - certB64 longitud:', certB64 ? certB64.length : 0);
                procesarCertificadoSeleccionado(certB64, estadoDiv, infoDiv);
            },
            function(type, message) {
                console.error('[FirmaDoc] ERROR type:', type);
                console.error('[FirmaDoc] ERROR message:', message);
                const esCancelado = (type && (type.includes('Cancel') || type.includes('cancel')))
                    || (message && message.toLowerCase().includes('cancel'))
                    || (message && message.toLowerCase().includes('cancelad'));

                const esConexion = type && (
                    type.includes('ApplicationNotFoundException') ||
                    type.includes('IOException') ||
                    type.includes('TimeoutException') ||
                    type.includes('CONNECTION_ERROR')
                );

                if (esCancelado) {
                    estadoDiv.innerHTML =
                        '<p class="text-muted small mb-2">Selección cancelada.</p>'
                        + '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">'
                        + '<i class="fas fa-id-card mr-1"></i> Seleccionar certificado</button>';
                    infoDiv.style.display = 'none';

                } else if (esConexion) {
                    _mostrarErrorCertificado(estadoDiv, infoDiv);

                } else {
                    estadoDiv.innerHTML =
                        '<p class="text-danger small mb-2">Error al conectar con AutoFirma.<br>'
                        + '<small><code>' + (type || '') + '</code><br>' + (message || '') + '</small></p>'
                        + '<button type="button" class="btn btn-outline-primary btn-sm" onclick="iniciarAutofirma()">'
                        + '<i class="fas fa-redo mr-1"></i> Reintentar</button>';
                    infoDiv.style.display = 'none';
                }
            }
        );
    } catch(e) {
        estadoDiv.innerHTML =
            '<p class="text-danger small mb-2">Error inesperado: ' + e.message + '</p>'
            + '<button type="button" class="btn btn-outline-secondary btn-sm" onclick="iniciarAutofirma()">'
            + '<i class="fas fa-redo mr-1"></i> Reintentar</button>';
    }
}

/**
 * El certificado SSL de AutoFirma no está aceptado en este navegador.
 * AutoFirma usa un puerto ALEATORIO en cada sesión, por lo que no es posible
 * que el usuario acepte el certificado navegando a la URL — AutoFirma ya se habría cerrado.
 *
 * La única solución fiable es importar el certificado raíz de AutoFirma en Chrome.
 * AutoFirma lo instala en el sistema durante la instalación en:
 *   Windows: C:\Program Files\AutoFirma\AutoFirma_ROOT.cer
 *   macOS:   /Applications/AutoFirma.app/Contents/Resources/AutoFirma_ROOT.cer
 *   Linux:   /usr/lib/autofirma/AutoFirma_ROOT.cer
 *
 * Chrome usa su propio almacén de certificados en Windows/Linux.
 * En Windows hay que importarlo en el almacén del sistema (que Chrome sí lee).
 */
function _mostrarErrorCertificado(estadoDiv, infoDiv) {
    estadoDiv.innerHTML =
        '<p class="text-danger small mb-2">'
        + '<strong><i class="fas fa-shield-alt mr-1"></i>Configuración necesaria (una sola vez)</strong><br>'
        + '<small class="text-muted">El navegador bloquea la comunicación con AutoFirma por su certificado de seguridad.</small>'
        + '</p>'
        + '<div class="text-left small mb-3">'

        // Windows
        + '<div class="mb-2">'
        + '<strong><i class="fab fa-windows mr-1"></i>Windows (Chrome/Edge):</strong>'
        + '<ol style="padding-left:18px;margin:4px 0">'
        + '<li>Abre <code>C:\\Program Files\\AutoFirma\\</code></li>'
        + '<li>Doble clic en <code>AutoFirma_ROOT.cer</code></li>'
        + '<li>Pulsa <strong>Instalar certificado</strong> → <strong>Equipo local</strong> → <strong>Siguiente</strong></li>'
        + '<li>Elige <strong>Entidades de certificación raíz de confianza</strong> → <strong>Finalizar</strong></li>'
        + '<li>Reinicia Chrome y vuelve a intentarlo.</li>'
        + '</ol>'
        + '</div>'

        // Firefox
        + '<details class="mb-1">'
        + '<summary><strong><i class="fab fa-firefox mr-1"></i>Firefox</strong> — instrucciones</summary>'
        + '<ol style="padding-left:18px;margin:4px 0">'
        + '<li>Menú → <strong>Ajustes</strong> → busca <em>certificados</em></li>'
        + '<li>Pulsa <strong>Ver certificados</strong> → pestaña <strong>Autoridades</strong></li>'
        + '<li>Pulsa <strong>Importar</strong> → selecciona <code>AutoFirma_ROOT.cer</code></li>'
        + '<li>Marca <em>Confiar para identificar sitios web</em> → Aceptar</li>'
        + '<li>Reinicia Firefox y vuelve a intentarlo.</li>'
        + '</ol>'
        + '</details>'

        + '</div>'
        + '<button type="button" class="btn btn-primary btn-sm" onclick="iniciarAutofirma()">'
        + '<i class="fas fa-redo mr-1"></i> Ya instalado — Reintentar</button>';

    infoDiv.style.display = 'none';
}




function procesarCertificadoSeleccionado(certB64, estadoDiv, infoDiv) {
    try {
        // Decodificar el certificado DER para extraer nombre y NIF
        const certInfo = parsearCertificado(certB64);

        certSeleccionado = {
            cert: certB64,
            nombre: certInfo.nombre,
            nif: certInfo.nif,
            expiry: certInfo.expiry
        };

        // Rellenar Y bloquear los campos — con certificado no se pueden modificar
        const nombreInput = document.getElementById('firma_nombre_input');
        const nifInput    = document.getElementById('firma_nif_input');

        if (nombreInput && certInfo.nombre) {
            nombreInput.value = certInfo.nombre;
            nombreInput.readOnly = true;
            nombreInput.style.backgroundColor = '#e9ecef';
            nombreInput.style.borderColor = '#ced4da';
            nombreInput.style.cursor = 'not-allowed';
            nombreInput.title = 'Campo bloqueado: dato obtenido del certificado digital acreditado';
        }
        if (nifInput && certInfo.nif) {
            nifInput.value = certInfo.nif;
            nifInput.readOnly = true;
            nifInput.style.backgroundColor = '#e9ecef';
            nifInput.style.borderColor = '#ced4da';
            nifInput.style.cursor = 'not-allowed';
            nifInput.title = 'Campo bloqueado: dato obtenido del certificado digital acreditado';
        }

        // Guardar el certificado en el campo hidden
        document.getElementById('firma_certificado_data').value = JSON.stringify({
            tipo: 'autofirma',
            cert: certB64,
            nombre: certInfo.nombre,
            nif: certInfo.nif,
            expiry: certInfo.expiry
        });

        // Mostrar info
        document.getElementById('cert-nombre-display').textContent = certInfo.nombre || 'Certificado seleccionado';
        document.getElementById('cert-nif-display').textContent    = certInfo.nif   || '—';
        document.getElementById('cert-expiry-display').textContent = certInfo.expiry || '—';

        estadoDiv.style.display = 'none';
        infoDiv.style.display   = 'block';

    } catch(e) {
        console.error('Error procesando certificado:', e);
        // Aunque falle el parseo, el certificado está seleccionado
        certSeleccionado = { cert: certB64, nombre: '', nif: '', expiry: '' };
        document.getElementById('firma_certificado_data').value = JSON.stringify({
            tipo: 'autofirma', cert: certB64
        });
        document.getElementById('cert-nombre-display').textContent = 'Certificado seleccionado';
        document.getElementById('cert-nif-display').textContent    = '—';
        document.getElementById('cert-expiry-display').textContent = '—';
        estadoDiv.style.display = 'none';
        infoDiv.style.display   = 'block';
    }
}

function parsearCertificado(certB64) {
    // Parser ASN.1 DER completo para extraer Subject y validez del certificado X.509
    try {
        const binary = atob(certB64);
        const buf = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) buf[i] = binary.charCodeAt(i);

        // --- Leer longitud ASN.1 ---
        function readLen(buf, pos) {
            if (buf[pos] < 0x80) return { len: buf[pos], next: pos + 1 };
            const n = buf[pos] & 0x7F;
            let len = 0;
            for (let i = 0; i < n; i++) len = (len << 8) | buf[pos + 1 + i];
            return { len, next: pos + 1 + n };
        }

        // --- Leer un nodo TLV ---
        function readNode(buf, pos) {
            const tag = buf[pos];
            const { len, next } = readLen(buf, pos + 1);
            return { tag, len, start: next, end: next + len };
        }

        // --- Iterar hijos de una secuencia ---
        function children(buf, start, end) {
            const result = [];
            let pos = start;
            while (pos < end) {
                const node = readNode(buf, pos);
                result.push(node);
                pos = node.end;
            }
            return result;
        }

        // --- Leer OID ---
        function readOID(buf, start, len) {
            const bytes = buf.slice(start, start + len);
            let oid = Math.floor(bytes[0] / 40) + '.' + (bytes[0] % 40);
            let val = 0;
            for (let i = 1; i < bytes.length; i++) {
                val = (val << 7) | (bytes[i] & 0x7F);
                if (!(bytes[i] & 0x80)) { oid += '.' + val; val = 0; }
            }
            return oid;
        }

        // --- Leer string (UTF8, Printable, IA5, BMP, T61) ---
        function readStr(buf, tag, start, len) {
            const bytes = buf.slice(start, start + len);
            if (tag === 0x1E) { // BMPString (UTF-16BE)
                let s = '';
                for (let i = 0; i < bytes.length - 1; i += 2)
                    s += String.fromCharCode((bytes[i] << 8) | bytes[i+1]);
                return s;
            }
            // UTF8String (0x0C), PrintableString (0x13), IA5String (0x16), T61 (0x14)
            let s = '';
            for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]);
            return s;
        }

        // --- Leer fecha UTCTime / GeneralizedTime ---
        function readDate(buf, tag, start, len) {
            let s = '';
            for (let i = 0; i < len; i++) s += String.fromCharCode(buf[start + i]);
            try {
                if (tag === 0x17) { // UTCTime: YYMMDDHHMMSSZ
                    const yr = parseInt(s.substr(0,2));
                    const year = yr >= 50 ? 1900+yr : 2000+yr;
                    return year + '-' + s.substr(2,2) + '-' + s.substr(4,2);
                } else { // GeneralizedTime: YYYYMMDDHHMMSSZ
                    return s.substr(0,4) + '-' + s.substr(4,2) + '-' + s.substr(6,2);
                }
            } catch(e) { return ''; }
        }

        // OIDs relevantes
        const OID_CN           = '2.5.4.3';
        const OID_SERIAL       = '2.5.4.5';
        const OID_GIVEN        = '2.5.4.42';
        const OID_SURNAME      = '2.5.4.4';
        const OID_COMMONNAME   = '2.5.4.3';

        // OIDs de NIF en certificados españoles (FNMT, ACCV, etc.)
        const OID_NIF_FNMT   = '1.3.6.1.4.1.5734.1.1';   // FNMT NIF
        const OID_DNI        = '2.16.724.1.3.5.4.1.1';

        // Extraer Subject: en X.509 DER la estructura es:
        // SEQUENCE { SEQUENCE(tbsCert) { ... SEQUENCE(validity) ... SEQUENCE(subject) ... } }
        // tbsCert = primer hijo del certificado raíz
        const root     = readNode(buf, 0);
        const tbsKids  = children(buf, root.start, root.end);
        const tbs      = tbsKids[0]; // tbsCertificate
        const tbsItems = children(buf, tbs.start, tbs.end);

        // Buscar validity y subject en tbsCertificate
        // Estructura: [version], serialNumber, signature, issuer, validity, subject, ...
        let validity = null, subject = null;
        let idx = 0;
        // Si hay version (tag 0xA0), saltar
        if (tbsItems[0] && tbsItems[0].tag === 0xA0) idx = 1;
        // serialNumber  → idx
        // signature     → idx+1
        // issuer        → idx+2
        // validity      → idx+3
        // subject       → idx+4
        if (tbsItems[idx+3]) validity = tbsItems[idx+3];
        if (tbsItems[idx+4]) subject  = tbsItems[idx+4];

        // Leer fecha de validez (notAfter = segundo hijo de validity)
        let expiry = '';
        if (validity) {
            const valKids = children(buf, validity.start, validity.end);
            if (valKids[1]) {
                expiry = readDate(buf, valKids[1].tag, valKids[1].start, valKids[1].len);
            }
        }

        // Extraer atributos del Subject
        let cn = '', serialNum = '', givenName = '', surname = '';
        const extraOIDs = {};

        if (subject) {
            // Subject = SEQUENCE of SET of SEQUENCE { OID, value }
            const rdns = children(buf, subject.start, subject.end); // SETs
            for (const rdn of rdns) {
                const attrs = children(buf, rdn.start, rdn.end); // SEQUENCEs
                for (const attr of attrs) {
                    const attrKids = children(buf, attr.start, attr.end);
                    if (attrKids.length < 2) continue;
                    const oidNode = attrKids[0];
                    const valNode = attrKids[1];
                    const oid = readOID(buf, oidNode.start, oidNode.len);
                    const val = readStr(buf, valNode.tag, valNode.start, valNode.len).trim();
                    if (oid === OID_CN)      cn         = val;
                    if (oid === OID_SERIAL)  serialNum  = val;
                    if (oid === OID_GIVEN)   givenName  = val;
                    if (oid === OID_SURNAME) surname    = val;
                    extraOIDs[oid] = val;
                }
            }
        }

        // Extraer NIF del serialNumber del Subject
        // Formatos comunes: "IDCES-12345678A", "12345678A", "DNI 12345678A"
        let nif = '';
        if (serialNum) {
            // FNMT formato: IDCES-12345678A o IDCEC-X1234567A (NIE)
            const m1 = serialNum.match(/IDCE[SC]-?([0-9A-Z]{8,9})/i);
            if (m1) nif = m1[1];
            else {
                // DNI: 8 dígitos + letra mayúscula
                const m2 = serialNum.match(/(\d{8}[A-Z])/);
                if (m2) nif = m2[1];
                else {
                    // NIE: X/Y/Z + 7 dígitos + letra
                    const m3 = serialNum.match(/([XYZ]\d{7}[A-Z])/);
                    if (m3) nif = m3[1];
                    else nif = serialNum; // mostrar el serialNumber tal cual
                }
            }
        }

        // Construir nombre preferiblemente de givenName+surname, sino del CN
        let nombre = '';
        if (givenName && surname) {
            nombre = (givenName + ' ' + surname).trim();
        } else if (cn) {
            // CN de FNMT: "APELLIDO1 APELLIDO2, NOMBRE - 12345678A"
            // Limpiar el NIF del final si aparece
            nombre = cn.replace(/-\s*[0-9A-Z]{8,9}\s*$/, '').replace(/,\s*/, ' ').trim();
            // Reordenar "APELLIDOS, NOMBRE" → "NOMBRE APELLIDOS"
            if (cn.includes(',')) {
                const parts = cn.split(',');
                if (parts.length === 2) nombre = parts[1].trim() + ' ' + parts[0].trim();
            }
        }

        console.log('[FirmaDoc] Cert parsed - nombre:', nombre, '| nif:', nif, '| expiry:', expiry);
        console.log('[FirmaDoc] Subject attrs - CN:', cn, '| serial:', serialNum, '| given:', givenName, '| surname:', surname);
        console.log('[FirmaDoc] Extra OIDs:', extraOIDs);

        return { nombre, nif, expiry };
    } catch(e) {
        console.error('[FirmaDoc] parsearCertificado error:', e);
        return { nombre: '', nif: '', expiry: '' };
    }
}

window.addEventListener('resize', () => {
    if (canvas) { limpiarCanvas(); ajustarCanvas(); }
});
